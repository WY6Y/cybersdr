# CyberSDR environment — copy to .env and edit before starting

# Host and port where rtl_tcp is running (can be remote over VPN/LAN)
RTL_TCP_HOST=192.168.1.100
RTL_TCP_PORT=1234

# RTL-SDR gain in dB — fallback used for any band not listed in RTL_GAIN_BANDS
RTL_GAIN=20

# Optional per-band manual gain override (dB), comma-separated band:gain pairs.
# Noise floor drops from 40m to 10m, so the higher bands generally want more
# gain to lift the noise above the RTL-SDR's own noise figure. Values are
# rounded by rtl_tcp to the nearest supported R828D gain step.
RTL_GAIN_BANDS=80m:19.7,40m:19.7,30m:20.7,20m:22.9,17m:25.4,15m:28.0,12m:29.7,10m:32.8

# Your amateur radio callsign and Maidenhead grid locator
MY_CALL=N0CALL
MY_GRID=AA00aa

# SQLite database path (inside container)
DB_PATH=/data/cybersdr.db

# Flask listen port
PORT=5020

# Set to true to upload decoded spots to WSPRnet
WSPRNET_UPLOAD=true

# Optional contact email included in the Nominatim reverse-geocode User-Agent
# (Nominatim's usage policy requests a contact so they can reach you if needed).
# Leave blank if you prefer not to include it.
NOMINATIM_CONTACT=
